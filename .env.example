# Neon / Postgres (pooled for the app)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/neondb?sslmode=require"
# Unpooled URL required for Prisma migrations
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Used for absolute URLs in Stripe redirects when needed
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth (openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# Seeded admin account (used by `npm run db:seed`)
ADMIN_EMAIL="admin@groundscollective.com"
ADMIN_PASSWORD="changeme-admin"
ADMIN_NAME="Site Admin"
