generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum SpaceSlug {
  GROUNDS
  GLASS_HOUSE
  SEASONAL_SETS
}

enum BookingPurpose {
  PHOTOGRAPHY
  EVENT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum UserRole {
  CUSTOMER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(CUSTOMER)
  bookings     Booking[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Space {
  id           String     @id @default(cuid())
  slug         SpaceSlug  @unique
  name         String
  description  String
  /// Marketing kicker on space cards (e.g. "Outdoors")
  kicker       String     @default("")
  /// Short tagline for booking page
  tagline      String     @default("")
  /// Home card blurb
  cardBlurb    String     @default("")
  /// Bullet list shown on home cards (JSON string[])
  bullets      Json       @default("[]")
  /// Allowed purposes (JSON BookingPurpose[])
  purposes     Json       @default("[\"PHOTOGRAPHY\"]")
  /// Hourly rate in cents
  hourlyRate   Int
  /// Max concurrent party size across overlapping bookings
  maxCapacity  Int
  openHour     Int        @default(8)
  closeHour    Int        @default(20)
  /// Long-form intro on the dedicated space page
  pageIntro    String     @default("")
  /// Additional body copy for the space page
  pageBody     String     @default("")
  /// Gallery images JSON: [{ url, alt, caption? }]
  gallery      Json       @default("[]")
  bookings     Booking[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

/// Individual themed rooms/sets under Seasonal Sets (admin-managed).
model SeasonalSet {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  description   String    @default("")
  imageUrl      String
  imageAlt      String    @default("")
  /// Hourly rate in cents
  hourlyRate    Int
  maxCapacity   Int       @default(1)
  openHour      Int       @default(8)
  closeHour     Int       @default(20)
  /// Inclusive availability window (YYYY-MM-DD)
  availableFrom String
  availableTo   String
  /// Allowed purposes (JSON BookingPurpose[])
  purposes      Json      @default("[\"PHOTOGRAPHY\"]")
  published     Boolean   @default(true)
  sortOrder     Int       @default(0)
  bookings      Booking[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([published, sortOrder])
  @@index([availableFrom, availableTo])
}

model Booking {
  id                    String         @id @default(cuid())
  spaceId               String
  space                 Space          @relation(fields: [spaceId], references: [id])
  seasonalSetId         String?
  seasonalSet           SeasonalSet?   @relation(fields: [seasonalSetId], references: [id])
  userId                String?
  user                  User?          @relation(fields: [userId], references: [id])
  customerName          String
  customerEmail         String
  customerPhone         String?
  purpose               BookingPurpose
  partySize             Int
  /// Local date of the booking (YYYY-MM-DD) for easy querying
  bookingDate           String
  startHour             Int
  endHour               Int
  hours                 Int
  /// Total amount in cents
  totalAmountCents      Int
  status                BookingStatus  @default(PENDING)
  stripeSessionId       String?        @unique
  stripePaymentIntentId String?
  cancelledAt           DateTime?
  /// CUSTOMER | ADMIN
  cancelSource          String?
  refundAmountCents     Int?
  penaltyAmountCents    Int?
  stripeRefundId        String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([spaceId, bookingDate, status])
  @@index([seasonalSetId, bookingDate, status])
  @@index([status, createdAt])
  @@index([userId])
  @@index([customerEmail])
}

model SiteSettings {
  id                   String   @id @default("default")
  siteName             String   @default("Grounds Collective")
  homeEyebrow          String
  homeLede             String
  footerText           String
  /// Cancellation tier rules JSON — see src/lib/cancellation.ts
  cancellationPolicy   Json     @default("{}")
  updatedAt            DateTime @updatedAt
}
